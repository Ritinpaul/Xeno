# ── Application ──────────────────────────────────────────────────────
NODE_ENV=development            # Set to 'production' for deployment
PORT=3000                       # Port to run the backend server on

# ── Auth ────────────────────────────────────────────────────────────
APP_ID=bloom-crm                # Application identifier
APP_SECRET=change-me-in-prod    # JWT signing secret (use a strong random value in production)

# ── Database ─────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string format:
# From your Supabase Dashboard: Settings -> Database -> Connection string -> URI
# Make sure to uncheck "Use connection pooling" if you want the direct connection (Port 5432)
# OR use the transaction pooler URL (Port 6543) if deploying serverless.
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Channel Service ──────────────────────────────────────────────────
# In production, CHANNEL_SERVICE_URL would point to a separate deployed service.
# For local development, the channel service runs within the same process
# as a separate tRPC router (channel.*), simulating the two-service architecture.
CHANNEL_SERVICE_URL=http://localhost:3000/api/channel

# ── Vite Dev Server (frontend) ────────────────────────────────────────
# VITE_API_URL is used by the frontend to reach the tRPC backend
VITE_API_URL=http://localhost:3000
